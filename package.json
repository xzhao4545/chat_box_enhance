{
  "name": "chat_box_enhance",
  "version": "0.0.5",
  "type": "module",
  "description": "为多个AI聊天平台生成智能对话大纲，支持实时更新、层级结构、主题切换，提升聊天体验和内容导航效率",
  "main": "dist/index.js",
  "repository": "https://github.com/xzhao4545/chat_box_enhance",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "watch": "rollup -c rollup.config.js -w",
    "serve": "node scripts/serve.js",
    "dev": "concurrently \"rollup -c rollup.config.js -w\" \"node scripts/serve.js\"",
    "gen-dev-header": "node scripts/generate-dev-header.js"
  },
  "keywords": [],
  "author": "xzhao",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^22.13.1",
    "@types/tampermonkey": "^5.0.4",
    "concurrently": "^9.2.1",
    "magic-string": "^0.30.21",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.30.2"
}
